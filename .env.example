# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Eigen SMTP (AI-Group.nl) ---
SMTP_HOST=smtp.jouwhosting.nl
SMTP_PORT=587
SMTP_USER=nostradamus@ai-group.nl
SMTP_PASS=geheim-wachtwoord

# Afzender en ontvanger (komma-gescheiden voor meerdere adressen)
MAIL_FROM=Nostradamus <nostradamus@ai-group.nl>
MAIL_TO=ontvanger@voorbeeld.nl

# --- Beveiliging cron-endpoint (aanbevolen) ---
# Zet dit ook in Vercel; Vercel Cron stuurt 'm automatisch mee als Bearer-token.
CRON_SECRET=verzin-een-lange-random-string
